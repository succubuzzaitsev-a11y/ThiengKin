# ThiengKin Supabase config (M2) — TEMPLATE
# ===========================================
# Copy this file to `thiengKin.env` and fill in real values.
#   cp thiengKin.env.example thiengKin.env   (then edit)
#
# Get keys from: https://supabase.com/dashboard/project/<PROJECT_REF>/settings/api
# Get db password: https://supabase.com/dashboard/project/<PROJECT_REF>/settings/database
#                  (Database Settings → "Reset database password")
#
# Fields:
#   - SUPABASE_URL: Project URL (e.g. https://abcdefgh.supabase.co)
#   - SUPABASE_SERVICE_ROLE_KEY: Secret/service_role key (NOT anon/Publishable)
#     ⚠️  KEEP SECRET. Server-side only — never embed in Android app.
#   - SUPABASE_DB_PASSWORD: Postgres connection password (used by migration scripts).
#     ⚠️  KEEP SECRET. Used by `scripts/apply-migrations.mjs` to apply DDL via pooler.
#     Should be DIFFERENT from your Supabase account login password.

SUPABASE_URL=https://YOUR_PROJECT.supabase.co
SUPABASE_SERVICE_ROLE_KEY=sb_secret_YOUR_SECRET_KEY_HERE
SUPABASE_DB_PASSWORD=YOUR_DB_PASSWORD_HERE
